def gen_fibonacci(n):
    """A generator function that yields the Fibonacci sequence up to the first n numbers."""
    # Track how many numbers have been yielded
    count = 0
    # Initialize the first two terms of the Fibonacci sequence
    a, b = 0, 1
    # Loop until we have yielded exactly  n numbers
    while count < n:
        yield a
        # Calculate next term and shift values forward
        a, b = b, a + b
        count += 1

